classDiagram
    %% PawPal+ final UML — reflects the implementation in pawpal_system.py.
    %% Key changes from the Phase 1 draft:
    %%   - Tasks now live on Pet (not Owner).
    %%   - Task gained a due_date + recurrence (next_occurrence).
    %%   - DailyPlan / ScheduledTask were dropped; Scheduler works directly on
    %%     (Pet, Task) pairs and returns ordered/filtered lists.

    class Task {
        +str description
        +str time
        +str frequency
        +str priority
        +bool completed
        +date due_date
        +mark_complete() void
        +mark_incomplete() void
        +toggle() bool
        +priority_rank() int
        +is_recurring() bool
        +next_occurrence() Task
        +sort_key() tuple
    }

    class Pet {
        +str name
        +str species
        +str breed
        +list~Task~ tasks
        +add_task(task Task) Task
        +remove_task(task Task) void
        +pending_tasks() list~Task~
        +completed_tasks() list~Task~
    }

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet Pet) Pet
        +get_pet(name str) Pet
        +all_tasks() list~Task~
        +all_tasks_with_pet() list
    }

    class Scheduler {
        +Owner owner
        +all_tasks() list
        +pending_tasks() list
        +daily_schedule() list
        +sort_by_time(tasks list) list~Task~
        +filter_by_status(completed bool) list
        +filter_by_pet(pet_name str) list~Task~
        +mark_task_complete(task Task) Task
        +mark_complete(task Task) Task
        +detect_conflicts() list~str~
        +summary() dict
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler "1" --> "1" Owner : reads
    Scheduler ..> Pet : updates (recurrence)
    Scheduler ..> Task : sorts / filters
